{
  "system": "Naye Core",
  "component": "OpenClaw Execution Policy",
  "version": "0.2.0",
  "enabled": true,
  "mode": "controlled_real_execution",
  "defaultAction": "require_approval",
  "policySupportsRealExecution": true,
  "executorImplemented": true,
  "realExecutionEnabled": true,
  "dryRunOnly": false,
  "philosophy": {
    "goal": "Naye debe poder actuar de forma útil en el proyecto, no solo observar.",
    "principle": "Permitir acciones reales dentro del espacio autorizado y bloquear solo acciones sensibles, destructivas o fuera de alcance."
  },
  "requirements": {
    "requireProposalApproval": true,
    "requireExecutionPlan": true,
    "requireExecutionApproval": true,
    "requireDryRunBeforeRealExecution": true,
    "requireFinalExecutorGate": true,
    "requireAuditLog": true,
    "authorizationRole": "Usuario Administrador designado"
  },
  "workspaceScope": {
    "primaryWorkspace": "F:/NayeVault",
    "projectRoot": "F:/NayeVault/naye-core",
    "runtimeRoot": "F:/NayeVault/openclaw/fresh/runtime",
    "allowedReadPaths": [
      "F:/NayeVault"
    ],
    "allowedWritePaths": [
      "F:/NayeVault"
    ],
    "allowedProjectPaths": [
      "F:/NayeVault/naye-core",
      "F:/NayeVault/openclaw/fresh",
      "F:/NayeVault/core",
      "F:/NayeVault/devices",
      "F:/NayeVault/logs"
    ]
  },
  "capabilities": {
    "allowReadFilesInWorkspace": true,
    "allowCreateFilesInWorkspace": true,
    "allowEditFilesInWorkspace": true,
    "allowAppendFilesInWorkspace": true,
    "allowCreateDirectoriesInWorkspace": true,
    "allowMoveFilesInWorkspaceWithApproval": true,
    "allowDeleteFilesWithExplicitApprovalAndBackup": true,
    "allowShellForWhitelistedCommands": true,
    "allowNpmScripts": true,
    "allowNodeScripts": true,
    "allowGitStatus": true,
    "allowGitDiff": true,
    "allowGitAdd": true,
    "allowGitCommitWithApproval": true,
    "allowPackageInstallWithApproval": true,
    "allowNetworkWithApproval": true,
    "allowExternalProvidersWithApproval": true,
    "allowWorkspaceExpansionWithApproval": true
  },
  "blockedSensitiveAccess": {
    "allowCredentialAccess": false,
    "allowCookies": false,
    "allowTokens": false,
    "allowBrowserProfiles": false,
    "allowWhatsAppData": false,
    "allowPasswordManagers": false,
    "allowSshKeys": false,
    "allowPrivateKeys": false,
    "allowSystemSecrets": false
  },
  "blockedPaths": [
    "C:/Windows",
    "C:/Program Files",
    "C:/Program Files (x86)",
    "C:/Users",
    "F:/.ssh",
    "F:/System Volume Information",
    "F:/$Recycle.Bin"
  ],
  "blockedFilePatterns": [
    ".env",
    ".env.*",
    "*token*",
    "*secret*",
    "*credential*",
    "*password*",
    "*.key",
    "*.pem",
    "*.pfx",
    "*.p12",
    "cookies.sqlite",
    "Login Data",
    "Local State"
  ],
  "allowedCommands": [
    {
      "commandId": "npm_run",
      "description": "Ejecutar scripts npm del proyecto.",
      "executable": "npm",
      "allowedArgsPrefix": [
        "run"
      ],
      "cwd": "F:/NayeVault/naye-core",
      "requiresApproval": true,
      "requiresAuditLog": true
    },
    {
      "commandId": "node_project_script",
      "description": "Ejecutar scripts Node dentro de src.",
      "executable": "node",
      "allowedPathPrefix": "F:/NayeVault/naye-core/src",
      "cwd": "F:/NayeVault/naye-core",
      "requiresApproval": true,
      "requiresAuditLog": true
    },
    {
      "commandId": "git_status",
      "description": "Consultar estado Git.",
      "executable": "git",
      "allowedExactArgs": [
        "status"
      ],
      "cwd": "F:/NayeVault/naye-core",
      "requiresApproval": false,
      "requiresAuditLog": true
    },
    {
      "commandId": "git_diff",
      "description": "Consultar diferencias Git.",
      "executable": "git",
      "allowedExactArgs": [
        "diff"
      ],
      "cwd": "F:/NayeVault/naye-core",
      "requiresApproval": false,
      "requiresAuditLog": true
    },
    {
      "commandId": "git_add",
      "description": "Preparar archivos para commit.",
      "executable": "git",
      "allowedArgsPrefix": [
        "add"
      ],
      "cwd": "F:/NayeVault/naye-core",
      "requiresApproval": true,
      "requiresAuditLog": true
    },
    {
      "commandId": "git_commit",
      "description": "Crear commit local.",
      "executable": "git",
      "allowedArgsPrefix": [
        "commit"
      ],
      "cwd": "F:/NayeVault/naye-core",
      "requiresApproval": true,
      "requiresAuditLog": true
    },
    {
      "commandId": "openclaw_version",
      "executable": "openclaw",
      "cwd": "F:/NayeVault/naye-core",
      "requiresApproval": true,
      "requiresAuditLog": true,
      "controlled": true,
      "networkAllowed": false,
      "externalProvidersAllowed": false,
      "allowedExactArgs": [
        "--version"
      ],
      "description": "Verify installed OpenClaw CLI version"
    },
    {
      "commandId": "openclaw_help",
      "executable": "openclaw",
      "cwd": "F:/NayeVault/naye-core",
      "requiresApproval": true,
      "requiresAuditLog": true,
      "controlled": true,
      "networkAllowed": false,
      "externalProvidersAllowed": false,
      "allowedExactArgs": [
        "--help"
      ],
      "description": "Show OpenClaw CLI help"
    },
    {
      "commandId": "openclaw_doctor",
      "executable": "openclaw",
      "cwd": "F:/NayeVault/naye-core",
      "requiresApproval": true,
      "requiresAuditLog": true,
      "controlled": true,
      "networkAllowed": false,
      "externalProvidersAllowed": false,
      "allowedExactArgs": [
        "doctor"
      ],
      "description": "Diagnose OpenClaw local setup"
    },
    {
      "commandId": "openclaw_status",
      "executable": "openclaw",
      "cwd": "F:/NayeVault/naye-core",
      "requiresApproval": true,
      "requiresAuditLog": true,
      "controlled": true,
      "networkAllowed": false,
      "externalProvidersAllowed": false,
      "allowedExactArgs": [
        "status"
      ],
      "description": "Show OpenClaw Gateway/channel/model status"
    },
    {
      "commandId": "openclaw_config_validate",
      "executable": "openclaw",
      "cwd": "F:/NayeVault/naye-core",
      "requiresApproval": true,
      "requiresAuditLog": true,
      "controlled": true,
      "networkAllowed": false,
      "externalProvidersAllowed": false,
      "allowedExactArgs": [
        "config",
        "validate"
      ],
      "description": "Validate OpenClaw configuration"
    },
    {
      "commandId": "openclaw_security",
      "executable": "openclaw",
      "cwd": "F:/NayeVault/naye-core",
      "requiresApproval": true,
      "requiresAuditLog": true,
      "controlled": true,
      "networkAllowed": false,
      "externalProvidersAllowed": false,
      "allowedExactArgs": [
        "security"
      ],
      "description": "Run OpenClaw security command group safely"
    },
    {
      "commandId": "openclaw_setup",
      "executable": "openclaw",
      "cwd": "F:/NayeVault/naye-core",
      "requiresApproval": true,
      "requiresAuditLog": true,
      "controlled": true,
      "networkAllowed": false,
      "externalProvidersAllowed": false,
      "allowedExactArgs": [
        "setup"
      ],
      "description": "Initialize baseline OpenClaw config and workspace without channels"
    },
    {
      "commandId": "openclaw_config_gateway_mode_local",
      "executable": "openclaw",
      "cwd": "F:/NayeVault/naye-core",
      "requiresApproval": true,
      "requiresAuditLog": true,
      "controlled": true,
      "networkAllowed": false,
      "externalProvidersAllowed": false,
      "allowedExactArgs": [
        "config",
        "set",
        "gateway.mode",
        "local"
      ],
      "description": "Set OpenClaw Gateway mode to local"
    },
    {
      "commandId": "openclaw_config_disable_memory_search",
      "executable": "openclaw",
      "cwd": "F:/NayeVault/naye-core",
      "requiresApproval": true,
      "requiresAuditLog": true,
      "controlled": true,
      "networkAllowed": false,
      "externalProvidersAllowed": false,
      "allowedExactArgs": [
        "config",
        "set",
        "agents.defaults.memorySearch.enabled",
        "false"
      ],
      "description": "Disable OpenAI semantic memory search until a provider is intentionally configured"
    }
  ],
  "destructiveActions": {
    "deleteFiles": "explicit_approval_and_backup_required",
    "overwriteFiles": "approval_required",
    "moveFiles": "approval_required",
    "installPackages": "approval_required",
    "networkRequests": "approval_required",
    "externalProviderCalls": "approval_required"
  },
  "controlledExecutor": {
    "enabled": true,
    "executorId": "openclaw-controlled-executor",
    "firstAllowedRealCommand": "npm run openclaw-status",
    "scope": "F:/NayeVault",
    "requiresFinalExecutorGate": true,
    "requiresAuditLog": true,
    "openclawCliEnabled": true,
    "openclawCommands": [
      "openclaw_version",
      "openclaw_help",
      "openclaw_doctor",
      "openclaw_status",
      "openclaw_config_validate",
      "openclaw_security"
    ]
  }
}